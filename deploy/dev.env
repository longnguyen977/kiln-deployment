# Kiln ATS — DEV deployment state.
# Consumed by docker compose via `--env-file deploy/dev.env`.
# deploy.sh updates VERSION_BACKEND / VERSION_FRONTEND on every deploy;
# edit SERVER_IP / API_URL by hand.

VERSION_BACKEND=0.0.0-dev
VERSION_FRONTEND=0.0.0-dev

# Backend secrets (loaded into the container at runtime)
BACKEND_ENV_FILE=./env/.env.dev

# Public URL the frontend redirects the browser to for backend calls.
# Must be reachable from the user's browser — some Next.js route
# handlers redirect to this URL directly (e.g. the OAuth init flow).
SERVER_IP=127.0.0.1
BACKEND_URL=http://localhost:8080

# URLs the backend uses for redirects back to the app and OAuth callbacks.
# Not secrets; committed so the team has one source of truth per env.
# Keep these in sync with the authorized redirect URIs registered in
# Google Cloud Console → OAuth credentials.
FRONTEND_URL=http://localhost:3000
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback
GMAIL_REDIRECT_URL=http://localhost:8080/api/v1/integrations/gmail/callback

# Cookie Domain attribute for session / OAuth-state cookies.
# Empty string = host-only (localhost dev). Use a leading dot for prod
# to share cookies across subdomains (e.g. .kilnai.io → app.kilnai.io
# AND api.kilnai.io both see the same cookie).
COOKIE_DOMAIN=

# Docker network mode: 'external' (bridge + host.docker.internal) or
# 'internal' (--network host). Managed by deploy.sh --internal/--external.
NETWORK_MODE=external
