# Kiln ATS — DEV deployment state.
# Consumed by docker compose via `--env-file deploy/dev.env`.
# deploy.sh updates VERSION_BACKEND / VERSION_FRONTEND on every deploy;
# edit SERVER_IP / API_URL by hand.

VERSION_BACKEND=0.0.0-dev
VERSION_FRONTEND=0.0.0-dev

# Backend secrets (loaded into the container at runtime)
BACKEND_ENV_FILE=./env/.env.dev

# Public URL the frontend redirects the browser to for backend calls
# (must be reachable from the browser — some Next.js route handlers
# redirect to this URL directly, e.g. the OAuth init flow).
SERVER_IP=127.0.0.1
BACKEND_URL=http://localhost:8080

# Docker network mode: 'external' (bridge + host.docker.internal) or
# 'internal' (--network host). Managed by deploy.sh --internal/--external.
NETWORK_MODE=external
