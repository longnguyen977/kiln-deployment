# Kiln ATS — PROD deployment state.
# Consumed by docker compose via `--env-file deploy/prod.env`.
# deploy.sh updates VERSION_BACKEND / VERSION_FRONTEND on every deploy;
# edit SERVER_IP / API_URL by hand before first prod deploy.

VERSION_BACKEND=0.0.0-prod
VERSION_FRONTEND=0.0.0-prod

# Backend secrets (loaded into the container at runtime)
BACKEND_ENV_FILE=./env/.env.prod

# Server-ip facing values — EDIT BEFORE FIRST DEPLOY
SERVER_IP=REPLACE_WITH_PROD_SERVER_IP
API_URL=http://REPLACE_WITH_PROD_SERVER_IP:8080
