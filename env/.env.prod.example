# Kiln ATS — PROD backend env (loaded into kiln-backend-service by docker compose).
# Copy to env/.env.prod and fill in real values. Keep the real file out of git.
#
# External Postgres runs on the host. Inside the container, reach it via
# host.docker.internal (wired up by extra_hosts in base-deploy.yml).

DATABASE_URL=postgres://USER:PASSWORD@host.docker.internal:5432/kiln?sslmode=disable
APP_PORT=8080
APP_ENV=production

# Goose — used only if you run migrations inside the container
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://USER:PASSWORD@host.docker.internal:5432/kiln?sslmode=disable
GOOSE_MIGRATION_DIR=./db/migrations

# JWT — MUST be a fresh 32+ char random string in prod
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_SECRET
JWT_ACCESS_EXPIRY=15d
JWT_REFRESH_EXPIRY=30d

# Google OAuth — the CLIENT_ID/SECRET are secrets (live here).
# The REDIRECT_URL / FRONTEND_URL / GMAIL_REDIRECT_URL are NOT secrets —
# they live in deploy/prod.env (committed) so the team has one source
# of truth per env. Compose passes them in as environment: overrides.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CRED_FILE=credentials/google_oauth.json

# Object storage — S3
STORAGE_PROVIDER=s3
S3_BUCKET=kiln-files-sg-prod
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Gemini
GOOGLE_AI_API_KEY=

# PostHog
POSTHOG_API_KEY=
POSTHOG_ENDPOINT=https://us.i.posthog.com
