# Kiln ATS — DEV backend env (loaded into kiln-backend-service by docker compose).
# Copy to env/.env.dev and fill in real values. Keep the real file out of git.
#
# External Postgres runs on the host. Inside the container, reach it via
# host.docker.internal (wired up by extra_hosts in base-dev.yml).

DATABASE_URL=postgres://curator:curator@host.docker.internal:5432/curator?sslmode=disable
APP_PORT=8080
APP_ENV=development

# Goose — used only if you run migrations inside the container
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://curator:curator@host.docker.internal:5432/curator?sslmode=disable
GOOSE_MIGRATION_DIR=./db/migrations

# JWT
JWT_SECRET=change-this-to-a-random-32-char-secret
JWT_ACCESS_EXPIRY=15d
JWT_REFRESH_EXPIRY=30d

# Google OAuth — set SERVER_IP portion to match the host you deploy on
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://127.0.0.1:8080/api/v1/auth/google/callback
GOOGLE_CRED_FILE=credentials/google_oauth.json

# Frontend URL (for OAuth redirects, email links, etc.)
FRONTEND_URL=http://127.0.0.1:3000

# Gmail integration OAuth
GMAIL_REDIRECT_URL=http://127.0.0.1:8080/api/v1/integrations/gmail/callback

# Object storage — S3
STORAGE_PROVIDER=s3
S3_BUCKET=kiln-files-sg-dev
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Gemini
GOOGLE_AI_API_KEY=

# PostHog
POSTHOG_API_KEY=
POSTHOG_ENDPOINT=https://us.i.posthog.com
